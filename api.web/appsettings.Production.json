{
  "Logging": {
    "LogLevel": {
      // Cosmos runs every query through EF Core, and at Information the provider logs a
      // full "Executed DbCommand" per query — a large chunk of Log Analytics ingestion.
      // Quiet it to Warning in Production only; appsettings.json keeps Information for
      // local development (Development environment does not load this file).
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  }
}
